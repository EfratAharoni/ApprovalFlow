# Copy this file to .env and fill in the values

# Database
POSTGRES_PASSWORD=approvalflow_dev

# LLM Provider — set ONE of the following
# Groq (free tier — recommended):
LLM_PROVIDER=groq
LLM_MODEL=groq/qwen-qwq-32b
LLM_API_KEY=your_groq_api_key_here

# Alternatively use the lighter/faster Groq model:
# LLM_MODEL=groq/llama-3.1-8b-instant

# Alternatively use Gemini:
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini/gemini-1.5-flash
# LLM_API_KEY=your_gemini_api_key

# Logging
LOG_LEVEL=INFO

# For Journey 4 (INV-1012) — inject payment failure to test saga compensation
PAYMENT_FAILURE_INJECT=false

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-here
JWT_EXPIRE_HOURS=24
# Users: comma-separated "username:password:role" entries
USERS=dana:pass123:submitter,lena:pass123:approver,admin:admin123:admin
