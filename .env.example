# Copy this file to .env and fill in the values

# Database
POSTGRES_PASSWORD=approvalflow_dev

# LLM Provider — set ONE of the following
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-1.5-flash
LLM_API_KEY=your_api_key_here

# Alternatively use Groq:
# LLM_PROVIDER=groq
# LLM_MODEL=groq/llama3-8b-8192
# LLM_API_KEY=your_groq_api_key

# Logging
LOG_LEVEL=INFO

# For Journey 4 (INV-1012) — inject payment failure to test saga compensation
PAYMENT_FAILURE_INJECT=false
